{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InScien",
  "version": "0.1.4",
  "identifier": "io.inscien.app",
  "build": {
    "beforeBuildCommand": "",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/inscien-backend"],
    "resources": {
      "../frontend/out": "frontend"
    },
    "longDescription": "InScien turns your Zotero library into a navigable map and audio narrations — fully local. The Map needs no model; narration uses a model you connect (local Ollama or an OpenAI key).",
    "shortDescription": "A local atlas of your Zotero library."
  }
}
