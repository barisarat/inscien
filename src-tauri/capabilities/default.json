{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "InScien desktop: spawn the backend sidecar, native folder picker, message dialogs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "inscien-backend", "sidecar": true, "args": true }]
    },
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-message",
    "updater:default"
  ]
}
